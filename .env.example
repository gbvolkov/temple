CMS_ENV=production
CMS_BOOTSTRAP_USER=admin
CMS_BOOTSTRAP_PASSWORD=replace-with-a-long-random-password
CMS_DATABASE=/data/cms.sqlite3
CMS_MEDIA_DIR=/data/media
CMS_MEDIA_DERIVATIVES_DIR=/data/media-derivatives
CMS_MAX_IMAGE_BYTES=15728640
CMS_MAX_VIDEO_BYTES=209715200
CMS_MAX_DOCUMENT_BYTES=52428800
CMS_LEGACY_CRAWL=/data/legacy-crawl-checkpoint.json
CMS_MEDIA_MANIFEST=/data/legacy-media-manifest.json
CMS_SESSION_HOURS=12
PUBLIC_BASE_URL=https://temple.gbvolkoff.name:8443
# Configure all SMTP fields and SUBMISSION_NOTIFY_TO, or leave all seven values empty.
SMTP_HOST=smtp.example.org
SMTP_PORT=587
SMTP_USER=replace-with-smtp-user
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM=site@example.org
SMTP_SECURITY=starttls
SUBMISSION_NOTIFY_TO=recipient@example.org
SUBMISSION_IP_HASH_SECRET=replace-with-a-long-random-secret
SUBMISSION_TRUSTED_PROXY_NETWORKS=127.0.0.0/8,::1/128,172.16.0.0/12
SUBMISSION_WORKER_INTERVAL_SECONDS=60
