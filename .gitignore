.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.uv-cache/
work/
.env
.env.*
!.env.example
baseline-*.tar.gz
baseline-*.tar.gz.sha256

# Runtime state. Keep the mount point in Git, never its contents.
/data/*
!/data/.gitkeep

# Defence in depth for databases, uploads, and local backup copies.
*.sqlite
*.sqlite3
*.sqlite-shm
*.sqlite-wal
*.sqlite3-shm
*.sqlite3-wal
/media/
/uploads/
/temple-backups/
